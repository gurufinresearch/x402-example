# Payer private for testing client-cmd (client-side, without 0x prefix)
EVM_PRIVATE_KEY=

# Address that receives payments (server-side, with 0x prefix)
EVM_PAYEE_ADDRESS=

# x402 facilitator URL (Coinbase hosted)
FACILITATOR_URL=

# Server URL the client connects to
SERVER_URL=http://localhost:4021

# Port the server listens on
PORT=4021

# Web demo port
WEB_PORT=4022
